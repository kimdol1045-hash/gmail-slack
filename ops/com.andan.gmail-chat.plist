<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.andan.gmail-chat</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/andan/googlechat/ops/run-gmail-chat.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/andan/googlechat</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/andan/googlechat/logs/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/andan/googlechat/logs/launchd.err.log</string>
</dict>
</plist>

